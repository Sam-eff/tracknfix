# Native localhost backend overrides.
# Copy this file to backend/.env.local when you want to run Django directly
# on your laptop without Docker. This file overrides backend/.env safely.

DEBUG=True
SECRET_KEY=replace-me-for-local-dev

DATABASE_URL=sqlite:///db.sqlite3
REDIS_URL=redis://localhost:6379/0

ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000,http://127.0.0.1:8000

FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://127.0.0.1:8000

AUTH_COOKIE_SECURE=False
AUTH_COOKIE_SAMESITE=Lax
AUTH_COOKIE_DOMAIN=
CSRF_COOKIE_SAMESITE=Lax
SESSION_COOKIE_SAMESITE=Lax

USE_HTTPS=False
SERVE_MEDIA=True
