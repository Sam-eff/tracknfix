{
  "rewrites": [
    {
      "source": "/api/v1/(.*)",
      "destination": "https://sam-eff-tracknfix-backend.hf.space/api/v1/$1"
    },
    {
      "source": "/media/(.*)",
      "destination": "https://sam-eff-tracknfix-backend.hf.space/media/$1"
    },
    {
      "source": "/((?!api/|media/|assets/|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
