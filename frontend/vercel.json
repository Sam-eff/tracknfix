{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "routes": [
    {
      "src": "/api/v1/(.*)",
      "dest": "https://sam-eff-tracknfix-backend.hf.space/api/v1/$1"
    },
    {
      "src": "/media/(.*)",
      "dest": "https://sam-eff-tracknfix-backend.hf.space/media/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
